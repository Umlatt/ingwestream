# ==============================================================================
# Ingwe Stream - Unified Tauri v2 & Frontend .gitignore
# ==============================================================================

# --- System & OS Logs ---
.DS_Store
Thumbs.db
*.log
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# --- IDEs & Editors ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Node/Frontend Dependencies & Build Artifacts ---
node_modules/
/dist/
/build/
.npm/
.eslintcache
.vite/

# --- Rust/Tauri Backend Artifacts ---
# Ignores the massive compiled binary caches generated by Cargo
/src-tauri/target/

# --- Environment & Secret Keys ---
# Never commit your private API keys or certificates to Git
.env
.env.local
.env.*.local
*.pfx
*.pem
*.key
src-tauri/certificates/

# --- Local Agent Caches ---
.copilot-history/
.claude-history/